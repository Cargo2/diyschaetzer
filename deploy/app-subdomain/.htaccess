# .htaccess für app.fliesen-kosten.de (Profi-App-Subdomain).
#
# Diese Subdomain liefert NIE prerendertes Marketing-HTML aus (das würde einen
# Hydration-Mismatch riskieren, da die App hier immer clientseitig/CSR laufen soll)
# und wird bewusst NICHT von Suchmaschinen indexiert (siehe robots.txt daneben).
# Dieselbe dist/project3/browser/-Ausgabe wird auf drei Hosts deployt (siehe
# .github/workflows/main.yml, flies.yml, app.yml); diese Datei überschreibt beim
# Deploy auf app.* das Standard-.htaccess aus public/.

<IfModule mod_headers.c>
  # Zusätzlich zur robots.txt: per HTTP-Header noindex/nofollow erzwingen,
  # auch für Crawler, die robots.txt ignorieren oder Header auswerten.
  Header set X-Robots-Tag "noindex, nofollow"

  # PWA: Service-Worker (ngsw-worker.js) und Manifest (ngsw.json) NIE cachen,
  # damit Clients nach einem Deploy zuverlässig Updates erhalten.
  <FilesMatch "^(ngsw-worker\.js|ngsw\.json)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>

  # ── Security-Header (SECURITY.md Pkt. 28) ─────────────────────────────────
  # Identisch zu public/.htaccess (Marketing-Host) – auf app.* laufen Login,
  # Supabase-Zugriffe und der PayPal-Abo-Button, daher dieselbe CSP.
  # Begründung je Direktive: siehe Kommentarblock in public/.htaccess.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://*.paypal.com https://*.paypalobjects.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https://*.paypal.com https://*.paypalobjects.com; connect-src 'self' https://mbfdfrjjabrwdyrpydld.supabase.co wss://mbfdfrjjabrwdyrpydld.supabase.co https://*.paypal.com https://*.paypalobjects.com; frame-src 'self' https://*.paypal.com https://*.paypalobjects.com; worker-src 'self'; manifest-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self' https://*.paypal.com; frame-ancestors 'self'"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # HSTS: Host erzwingt HTTPS; auf HTTP-Antworten ignorieren Browser den Header
  # per Spec, daher unbedenklich bedingungslos gesetzt. Kein preload.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Korrekten MIME-Typ für das Web-App-Manifest ausliefern.
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Echte Asset-Dateien (JS/CSS/Bilder/Fonts/PWA-Dateien etc.) direkt ausliefern,
  # wenn sie existieren. Bewusst KEIN genereller "-f"-Check wie im Standard-.htaccess
  # (public/.htaccess), da der Prerender-Build auch .html-Dateien (Startseite,
  # Ratgeber-/Kostenseiten) als echte Dateien ablegt – die sollen auf app.* aber
  # NICHT direkt ausgeliefert werden, sondern immer auf die CSR-Shell fallen.
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteCond %{REQUEST_URI} \.(js|mjs|css|map|ico|svg|png|jpg|jpeg|webp|avif|gif|woff|woff2|ttf|txt|xml|json|webmanifest|pdf)$ [NC]
  RewriteRule ^ - [L]

  # Alles andere (inkl. existierender prerenderter .html-Dateien wie index.html
  # oder /ratgeber/<slug>/index.html) auf die Client-Shell umleiten. So landet
  # auf app.* immer die CSR-App – auch künftige PWA-Dateien (ngsw.json,
  # ngsw-worker.js, manifest.webmanifest) bleiben über die Assets-Regel oben
  # weiterhin direkt erreichbar.
  RewriteRule ^ index.csr.html [L]
</IfModule>
