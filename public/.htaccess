# SPA-Fallback für die Angular-App (netcup/Apache).
#
# Seit Phase 16 wird statisch prerendert (outputMode: static): Inhaltsseiten
# (/, /ratgeber, /ratgeber/<slug>, /impressum, /datenschutz, /kontakt) liegen als
# echte HTML-Dateien/Verzeichnisse vor und werden direkt ausgeliefert. Alle übrigen,
# clientseitig gerenderten Routen (Rechner, Admin, Login, /geteilt/<token>, F5 darauf)
# fallen auf den CSR-Shell index.csr.html zurück – NICHT auf index.html, das jetzt die
# prerenderte Startseite ist.

# PWA: Der Service-Worker (ngsw-worker.js) und sein Manifest (ngsw.json) dürfen
# NIE gecacht werden, sonst bekommen Clients nach einem Deploy keine Updates.
<IfModule mod_headers.c>
  <FilesMatch "^(ngsw-worker\.js|ngsw\.json)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>

  # ── Security-Header (SECURITY.md Pkt. 28) ─────────────────────────────────
  # "always": Header auch auf Fehler-/Redirect-Antworten setzen.
  #
  # CSP evidenzbasiert aus dem Code abgeleitet:
  # - script-src: Angular-SSG/Hydration prerendert Inline-Scripts (Event-Replay,
  #   ng-event-dispatch-contract) → 'unsafe-inline' nötig (statisches Hosting,
  #   keine Nonces möglich). PayPal-JS-SDK (paypal-sdk-loader.service.ts) lädt
  #   von www.paypal.com und ggf. paypalobjects.com nach.
  # - style-src: Angular injiziert Komponenten-Styles als <style>-Tags →
  #   'unsafe-inline'; Google-Fonts-CSS via @import in styles.css.
  # - font-src: Google-Fonts-Dateien von fonts.gstatic.com.
  # - img-src: data:-SVG-Hintergrund (marketing-shell) + PayPal-Button-Grafiken.
  # - connect-src: Supabase (Auth/DB; wss: für evtl. Realtime) + PayPal-SDK-
  #   Logger/API-Calls.
  # - frame-src: PayPal rendert den Abo-Button in einem iframe von *.paypal.com.
  # - worker-src 'self': Angular Service Worker (ngsw-worker.js).
  # - form-action: 'self' + PayPal (SDK-Fallback-Flows posten an paypal.com).
  # - frame-ancestors 'self' (+ X-Frame-Options): kein Fremd-Framing (Clickjacking).
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://*.paypal.com https://*.paypalobjects.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https://*.paypal.com https://*.paypalobjects.com; connect-src 'self' https://mbfdfrjjabrwdyrpydld.supabase.co wss://mbfdfrjjabrwdyrpydld.supabase.co https://*.paypal.com https://*.paypalobjects.com; frame-src 'self' https://*.paypal.com https://*.paypalobjects.com; worker-src 'self'; manifest-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self' https://*.paypal.com; frame-ancestors 'self'"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # HSTS: beide Live-Hosts erzwingen HTTPS; auf HTTP-Antworten ignorieren Browser
  # den Header per Spec, daher unbedenklich bedingungslos gesetzt. Kein preload.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Korrekten MIME-Typ für das Web-App-Manifest ausliefern.
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # www → Apex-Domain (301). Ohne diese Regel liefert www.fliesen-kosten.de
  # die komplette Site als Duplikat aus (nur der Canonical zeigt auf non-www).
  RewriteCond %{HTTP_HOST} ^www\.fliesen-kosten\.de$ [NC]
  RewriteRule ^(.*)$ https://fliesen-kosten.de/$1 [R=301,L]

  # Bestehende Dateien unverändert ausliefern (JS/CSS/Assets, prerenderte .html).
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # Startseite: prerendertes index.html direkt ausliefern (die frühere
  # -d-Passthrough-Regel entfällt, daher hier explizit).
  RewriteRule ^$ index.html [L]

  # Prerenderte Verzeichnisrouten (mit oder ohne Trailing Slash) INTERN auf ihre
  # index.html abbilden. Kein externer 301 auf die Slash-Variante mehr –
  # Sitemap/Canonicals nutzen die slash-lose URL, die muss direkt 200 liefern
  # (sonst meldet die Search Console "Seite mit Weiterleitung"/"Umleitungsfehler").
  RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
  RewriteRule ^(.+?)/?$ $1/index.html [L]

  # Alles andere an den Client-Shell übergeben.
  RewriteRule ^ index.csr.html [L]
</IfModule>

# mod_dir würde Verzeichnis-URLs ohne Trailing Slash extern per 301 umleiten
# (Canonical↔Redirect-Konflikt in der Search Console) – abschalten. Directory-
# Listings sind trotzdem nicht möglich: jede Anfrage endet oben in einer Datei.
<IfModule mod_dir.c>
  DirectorySlash Off
</IfModule>
