# SPA-Fallback für die Angular-App (netcup/Apache).
#
# Seit Phase 16 wird statisch prerendert (outputMode: static): Inhaltsseiten
# (/, /ratgeber, /ratgeber/<slug>, /impressum, /datenschutz, /kontakt) liegen als
# echte HTML-Dateien/Verzeichnisse vor und werden direkt ausgeliefert. Alle übrigen,
# clientseitig gerenderten Routen (Rechner, Admin, Login, /geteilt/<token>, F5 darauf)
# fallen auf den CSR-Shell index.csr.html zurück – NICHT auf index.html, das jetzt die
# prerenderte Startseite ist.

# PWA: Der Service-Worker (ngsw-worker.js) und sein Manifest (ngsw.json) dürfen
# NIE gecacht werden, sonst bekommen Clients nach einem Deploy keine Updates.
<IfModule mod_headers.c>
  <FilesMatch "^(ngsw-worker\.js|ngsw\.json)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# Korrekten MIME-Typ für das Web-App-Manifest ausliefern.
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # www → Apex-Domain (301). Ohne diese Regel liefert www.fliesen-kosten.de
  # die komplette Site als Duplikat aus (nur der Canonical zeigt auf non-www).
  RewriteCond %{HTTP_HOST} ^www\.fliesen-kosten\.de$ [NC]
  RewriteRule ^(.*)$ https://fliesen-kosten.de/$1 [R=301,L]

  # Bestehende Dateien unverändert ausliefern (JS/CSS/Assets, prerenderte .html).
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # Startseite: prerendertes index.html direkt ausliefern (die frühere
  # -d-Passthrough-Regel entfällt, daher hier explizit).
  RewriteRule ^$ index.html [L]

  # Prerenderte Verzeichnisrouten (mit oder ohne Trailing Slash) INTERN auf ihre
  # index.html abbilden. Kein externer 301 auf die Slash-Variante mehr –
  # Sitemap/Canonicals nutzen die slash-lose URL, die muss direkt 200 liefern
  # (sonst meldet die Search Console "Seite mit Weiterleitung"/"Umleitungsfehler").
  RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
  RewriteRule ^(.+?)/?$ $1/index.html [L]

  # Alles andere an den Client-Shell übergeben.
  RewriteRule ^ index.csr.html [L]
</IfModule>

# mod_dir würde Verzeichnis-URLs ohne Trailing Slash extern per 301 umleiten
# (Canonical↔Redirect-Konflikt in der Search Console) – abschalten. Directory-
# Listings sind trotzdem nicht möglich: jede Anfrage endet oben in einer Datei.
<IfModule mod_dir.c>
  DirectorySlash Off
</IfModule>
